# ════════════════════════════════════════════════════════════════════════
# ⚠️ DEMO / ÖRNEK YAPILANDIRMA — "olduğu gibi" (as-is), garantisiz.
# Tüm değerler örnektir. Gerçek kullanımdan önce HER sırrı (AUTH_SECRET, DATABASE_URL,
# ADMIN_PASSWORD) değiştirin ve demo giriş bilgilerini kaldırın. Yasal sorumluluk
# yayına alan/işleten tarafa aittir — bkz. LICENSE / SORUMLULUK-REDDI.md.
# ════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────
# Local: postgresql://<user>@localhost:5432/turacente
# Prod: a managed Postgres connection string (Neon, Supabase, RDS, …)
DATABASE_URL="postgresql://user@localhost:5432/turacente"

# ── Site ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME="Tur Acente"
NEXT_PUBLIC_WHATSAPP="+90..."
# Public base URL — used for metadata/OG/sitemap. Set to the real domain in prod.
NEXT_PUBLIC_BASE_URL="http://localhost:3100"
# Search-engine indexing is OFF by default (a demo must not be indexed as a real
# agency). Set to "true" ONLY after you hold a real TÜRSAB licence and have replaced
# all placeholder/demo content.
ALLOW_INDEXING="false"

# ── Auth ──────────────────────────────────────────────────────────────
# Generate a strong secret: `openssl rand -base64 32`
AUTH_SECRET="change-me-to-a-long-random-string"
# Seeded demo admin (used by `npm run db:seed`)
ADMIN_EMAIL="admin@turacente.com"
ADMIN_PASSWORD="admin1234"

# ── Email (Resend) ────────────────────────────────────────────────────
# Leave RESEND_API_KEY empty to log emails to the console (dev transport).
# Set it (resend.com) + a verified EMAIL_FROM to send real emails.
RESEND_API_KEY=""
EMAIL_FROM="Tur Acente <onboarding@resend.dev>"

# ── Object storage for uploads (S3 / Cloudflare R2) ───────────────────
# Required in production — `public/uploads` is ephemeral on serverless hosts.
# Leave blank to use the local fallback (dev only).
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""            # public base URL of the bucket, e.g. https://cdn.example.com
S3_ENDPOINT=""             # R2/non-AWS endpoint, e.g. https://<acct>.r2.cloudflarestorage.com
S3_REGION="auto"           # R2 uses "auto"; AWS uses e.g. "eu-central-1"
