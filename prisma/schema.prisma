// Tur Acente — Prisma schema (executable bridge for docs/03-database-schema.md)
// Money = integer MINOR units (kuruş/cent) + ISO currency. Exchange rate = Decimal.
// Run: npx prisma migrate dev --name init  &&  npx prisma db seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────── enums ────────────────────────────
enum UserRealm {
  CUSTOMER
  STAFF
  B2B
}
enum TourStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  ARCHIVED
}
enum TourDateStatus {
  ACTIVE
  FULL
  CLOSED
  CANCELLED
}
enum TransportType {
  FLIGHT
  BUS
  CRUISE
  OWN_ARRANGEMENT
  MIXED
}
enum HotelCategory {
  THREE_STAR
  FOUR_STAR
  FIVE_STAR
  BOUTIQUE
  NONE
}
enum PaxType {
  ADULT
  CHILD_WITH_BED
  CHILD_NO_BED
  INFANT
}
enum RoomOccupancy {
  SINGLE
  DOUBLE
  TRIPLE
  QUAD
  FAMILY
}
enum ReservationStatus {
  NEW_REQUEST
  WAITING_PAYMENT
  PAYMENT_RECEIVED
  CONFIRMED
  WAITING_SUPPLIER
  CANCELLED
  REFUNDED
  COMPLETED
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  CASH
  AGENCY_CREDIT
  PARTIAL
}
enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}
enum RefundStatus {
  REQUESTED
  APPROVED
  PROCESSED
  REJECTED
}
enum ChannelType {
  DIRECT_WEB
  ADMIN
  B2B
  PHONE
  WHATSAPP
}
enum SupplierType {
  HOTEL
  DMC
  AIRLINE
  TRANSFER
  GUIDE
  INSURANCE
  OTHER
}
enum DocumentType {
  PASSPORT
  ID_CARD
  VISA
  VOUCHER
  INVOICE
  PROFORMA
  CONTRACT
  OTHER
}
enum MessageChannel {
  WEB
  EMAIL
  WHATSAPP
  PHONE
  SMS
}
enum MessageDirection {
  IN
  OUT
}
enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  LOST
}
enum NotificationType {
  RES_NEW
  RES_CONFIRMED
  PAYMENT_RECEIVED
  DOC_MISSING
  TOUR_REMINDER
  CANCELLATION
  LOW_QUOTA
  ADMIN_ALERT
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}
enum AgencyStatus {
  PENDING
  ACTIVE
  SUSPENDED
}
enum AgencyTier {
  STANDARD
  GOLD
  NET
}
enum CommissionStatus {
  ACCRUED
  INVOICED
  PAID
  CANCELLED
}
enum CampaignKind {
  EARLY_BIRD
  LAST_MINUTE
  PROMO
}
enum ContentStatus {
  DRAFT
  PUBLISHED
}
// ──────────────────────────── auth ─────────────────────────────
model User {
  id              String     @id @default(cuid())
  email           String     @unique
  phone           String?
  passwordHash    String?
  realm           UserRealm
  firstName       String
  lastName        String
  locale          String     @default("tr")
  emailVerifiedAt DateTime?
  twoFactorSecret String?
  lastLoginAt     DateTime?
  isActive        Boolean    @default(true)

  customerId String?   @unique
  customer   Customer? @relation("CustomerLogin", fields: [customerId], references: [id])

  userRoles            UserRole[]
  agencyMemberships    AgencyUser[]
  assignedReservations Reservation[] @relation("AssignedAgent")
  recordedPayments     Payment[]
  uploadedDocuments    Document[]
  sentMessages         Message[]
  assignedLeads        Lead[]
  blogPosts            BlogPost[]
  auditLogs            AuditLog[]
  requestedRefunds     Refund[]      @relation("RefundRequestedBy")
  approvedRefunds      Refund[]      @relation("RefundApprovedBy")
  updatedSettings      Setting[]
  notifications        Notification[]

  // crm + cms back-relations
  ownedContacts      Customer[]       @relation("ContactOwner")
  ownedOpportunities CrmOpportunity[]
  assignedActivities CrmActivity[]    @relation("ActivityAssignee")
  createdActivities  CrmActivity[]    @relation("ActivityCreator")
  createdSegments    CrmSegment[]
  emailCampaigns     EmailCampaign[]
  uploadedMedia      Media[]          @relation("MediaUploader")
  authoredPages      Page[]           @relation("PageAuthor")
  pageRevisions      PageRevision[]   @relation("PageRevisionEditor")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([realm])
  @@map("users")
}

model Role {
  id              String           @id @default(cuid())
  key             String           @unique
  name            String
  realm           UserRealm
  isSystem        Boolean          @default(false)
  rolePermissions RolePermission[]
  userRoles       UserRole[]
  @@map("roles")
}

model Permission {
  id              String           @id @default(cuid())
  key             String           @unique
  description     String?
  rolePermissions RolePermission[]
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@id([userId, roleId])
  @@map("user_roles")
}

// ──────────────────────────── crm ──────────────────────────────
model Customer {
  id               String         @id @default(cuid())
  user             User?          @relation("CustomerLogin")
  firstName        String
  lastName         String
  email            String
  phone            String
  nationality      String?
  birthDate        DateTime?
  city             String?
  marketingConsent Boolean        @default(false)
  kvkkConsentAt    DateTime?
  notes            String?
  source           ChannelType    @default(DIRECT_WEB)

  // crm
  lifecycleStage   LifecycleStage @default(LEAD)
  leadSource       String?
  ownerId          String?
  owner            User?          @relation("ContactOwner", fields: [ownerId], references: [id])

  reservations     Reservation[]
  documents        Document[]
  messages         Message[]
  favorites        Favorite[]
  opportunities    CrmOpportunity[]
  activities       CrmActivity[]
  tags             CustomerTag[]
  emailRecipients  EmailCampaignRecipient[]
  segmentMembers   CrmSegmentMember[]

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  @@index([email])
  @@index([phone])
  @@index([lifecycleStage])
  @@index([ownerId])
  @@map("customers")
}

model Favorite {
  id         String   @id @default(cuid())
  customerId String
  tourId     String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tour       Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  @@unique([customerId, tourId])
  @@map("favorites")
}

model Lead {
  id            String       @id @default(cuid())
  name          String
  email         String
  phone         String
  message       String?
  channel       ChannelType  @default(DIRECT_WEB)
  status        LeadStatus   @default(NEW)
  destinationId String?
  tourId        String?
  assignedToId  String?
  destination   Destination? @relation(fields: [destinationId], references: [id])
  tour          Tour?        @relation(fields: [tourId], references: [id])
  assignedTo    User?        @relation(fields: [assignedToId], references: [id])
  submissions   FormSubmission[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  @@index([status])
  @@map("leads")
}

model Document {
  id           String                @id @default(cuid())
  type         DocumentType
  fileKey      String
  fileName     String
  mimeType     String
  sizeBytes    Int
  isSensitive  Boolean               @default(false)
  reservationId String?
  passengerId  String?
  customerId   String?
  uploadedById String?
  reservation  Reservation?          @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  passenger    ReservationPassenger? @relation(fields: [passengerId], references: [id])
  customer     Customer?             @relation(fields: [customerId], references: [id])
  uploadedBy   User?                 @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime              @default(now())
  @@index([reservationId])
  @@map("documents")
}

model Message {
  id           String           @id @default(cuid())
  reservationId String?
  customerId   String?
  agencyId     String?
  senderUserId String?
  channel      MessageChannel   @default(WEB)
  direction    MessageDirection
  subject      String?
  body         String
  isRead       Boolean          @default(false)
  reservation  Reservation?     @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  customer     Customer?        @relation(fields: [customerId], references: [id])
  agency       Agency?          @relation(fields: [agencyId], references: [id])
  sender       User?            @relation(fields: [senderUserId], references: [id])
  createdAt    DateTime         @default(now())
  @@index([reservationId])
  @@index([customerId])
  @@map("messages")
}

// ──────────────────────────── catalog ──────────────────────────
model Destination {
  id             String     @id @default(cuid())
  slug           String     @unique
  nameTr         String
  nameEn         String?
  country        String
  heroImageKey   String?
  summaryTr      String?
  descriptionTr  String?
  seoTitle       String?
  seoDescription String?
  isFeatured     Boolean    @default(false)
  sortOrder      Int        @default(0)
  isActive       Boolean    @default(true)
  tours          Tour[]
  leads          Lead[]
  campaigns      Campaign[]
  blogPosts      BlogPost[]
  opportunities  CrmOpportunity[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  @@index([isFeatured])
  @@map("destinations")
}

model Tour {
  id                String      @id @default(cuid())
  destinationId     String
  slug              String      @unique
  titleTr           String
  summaryTr         String
  descriptionTr     String
  durationDays      Int
  durationNights    Int
  transportType     TransportType @default(FLIGHT)
  hotelCategory     HotelCategory @default(FOUR_STAR)
  visaRequired      Boolean     @default(false)
  isGuided          Boolean     @default(true)
  hasFreeTime       Boolean     @default(true)
  basePriceMinor    Int
  baseCurrency      String      @default("EUR")
  status            TourStatus  @default(DRAFT)
  isFeatured        Boolean     @default(false)
  isCampaign        Boolean     @default(false)
  ratingAvg         Float?
  ratingCount       Int         @default(0)
  includedServices  Json        @default("[]")
  excludedServices  Json        @default("[]")
  meetingPoint      String?
  visaNotes         String?
  cancellationPolicy String?
  reservationTerms  String?
  seoTitle          String?
  seoDescription    String?
  supplierId        String?

  destination   Destination         @relation(fields: [destinationId], references: [id])
  supplier      Supplier?           @relation(fields: [supplierId], references: [id])
  images        TourImage[]
  itineraryDays TourItineraryDay[]
  faqs          Faq[]
  tourDates     TourDate[]
  optionalExtras OptionalExtra[]
  reservations  Reservation[]
  favorites     Favorite[]
  campaigns     Campaign[]          @relation("CampaignTour")
  testimonials  Testimonial[]
  blogPosts     BlogPost[]
  leads         Lead[]
  opportunities CrmOpportunity[]

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([destinationId])
  @@index([status])
  @@index([isFeatured])
  @@index([isCampaign])
  @@map("tours")
}

model TourImage {
  id        String  @id @default(cuid())
  tourId    String
  fileKey   String
  alt       String
  sortOrder Int     @default(0)
  isCover   Boolean @default(false)
  tour      Tour    @relation(fields: [tourId], references: [id], onDelete: Cascade)
  @@index([tourId])
  @@map("tour_images")
}

model TourItineraryDay {
  id            String  @id @default(cuid())
  tourId        String
  dayNumber     Int
  titleTr       String
  descriptionTr String
  meals         Json?   // {b:bool,l:bool,d:bool}
  overnightCity String?
  tour          Tour    @relation(fields: [tourId], references: [id], onDelete: Cascade)
  @@unique([tourId, dayNumber])
  @@map("tour_itinerary_days")
}

model Faq {
  id          String   @id @default(cuid())
  tourId      String?
  questionTr  String
  answerTr    String
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  tour        Tour?    @relation(fields: [tourId], references: [id], onDelete: Cascade)
  @@map("faqs")
}

model Campaign {
  id                    String       @id @default(cuid())
  code                  String       @unique
  nameTr                String
  kind                  CampaignKind
  percentOff            Int?
  amountOffMinor        Int?
  startsAt              DateTime
  endsAt                DateTime
  isActive              Boolean      @default(true)
  appliesToTourId       String?
  appliesToDestinationId String?
  appliesToTour         Tour?        @relation("CampaignTour", fields: [appliesToTourId], references: [id])
  appliesToDestination  Destination? @relation(fields: [appliesToDestinationId], references: [id])
  reservations          Reservation[]
  createdAt             DateTime     @default(now())
  @@map("campaigns")
}

// ──────────────────────────── inventory ────────────────────────
model RoomType {
  id          String       @id @default(cuid())
  code        String       @unique
  nameTr      String
  occupancy   RoomOccupancy
  maxAdults   Int
  maxChildren Int
  sortOrder   Int          @default(0)
  prices      TourPrice[]
  passengers  ReservationPassenger[]
  @@map("room_types")
}

model TourDate {
  id               String         @id @default(cuid())
  tourId           String
  startDate        DateTime
  endDate          DateTime
  quota            Int
  seatsSold        Int            @default(0)
  seatsHeld        Int            @default(0)
  status           TourDateStatus @default(ACTIVE)
  baseCurrency     String         @default("EUR")
  earlyBirdUntil   DateTime?
  lastMinuteFrom   DateTime?
  flightNotes      String?
  transportNotes   String?
  supplierConfirmed Boolean       @default(false)
  supplierRef      String?
  cutoffDate       DateTime?

  tour        Tour                 @relation(fields: [tourId], references: [id], onDelete: Cascade)
  prices      TourPrice[]
  allocations TourDateAllocation[]
  reservations Reservation[]
  seatHolds   SeatHold[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tourId, startDate])
  @@index([status])
  @@map("tour_dates")
}

model TourPrice {
  id                  String   @id @default(cuid())
  tourDateId          String
  roomTypeId          String
  paxType             PaxType
  priceMinor          Int
  currency            String   @default("EUR")
  earlyBirdPriceMinor Int?
  lastMinutePriceMinor Int?
  childMinAge         Int?
  childMaxAge         Int?
  tourDate            TourDate @relation(fields: [tourDateId], references: [id], onDelete: Cascade)
  roomType            RoomType @relation(fields: [roomTypeId], references: [id])
  @@unique([tourDateId, roomTypeId, paxType])
  @@index([tourDateId])
  @@map("tour_prices")
}

model OptionalExtra {
  id          String  @id @default(cuid())
  tourId      String?
  nameTr      String
  descriptionTr String?
  priceMinor  Int
  currency    String  @default("EUR")
  perPax      Boolean @default(true)
  isActive    Boolean @default(true)
  tour        Tour?   @relation(fields: [tourId], references: [id])
  reservationExtras ReservationExtra[]
  @@map("optional_extras")
}

// ──────────────────────────── booking ──────────────────────────
model SeatHold {
  id            String       @id @default(cuid())
  tourDateId    String
  seats         Int
  sessionToken  String
  reservationId String?
  expiresAt     DateTime
  tourDate      TourDate     @relation(fields: [tourDateId], references: [id], onDelete: Cascade)
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
  createdAt     DateTime     @default(now())
  @@index([tourDateId])
  @@index([expiresAt])
  @@map("seat_holds")
}

model Reservation {
  id              String            @id @default(cuid())
  reference       String            @unique
  customerId      String
  tourId          String
  tourDateId      String
  agencyId        String?
  assignedToId    String?
  campaignId      String?
  channel         ChannelType       @default(DIRECT_WEB)
  status          ReservationStatus @default(NEW_REQUEST)

  adults          Int               @default(1)
  children        Int               @default(0)
  infants         Int               @default(0)

  currency        String            @default("TRY")
  exchangeRate    Decimal           @db.Decimal(12, 4)
  exchangeRateAt  DateTime
  subtotalMinor   Int               @default(0)
  extrasMinor     Int               @default(0)
  discountMinor   Int               @default(0)
  totalMinor      Int               @default(0)
  paidMinor       Int               @default(0)
  balanceMinor    Int               @default(0)

  paymentMethod   PaymentMethod?
  notesInternal   String?
  cancellationReason String?
  cancelledAt     DateTime?
  completedAt     DateTime?

  customer    Customer  @relation(fields: [customerId], references: [id])
  tour        Tour      @relation(fields: [tourId], references: [id])
  tourDate    TourDate  @relation(fields: [tourDateId], references: [id])
  agency      Agency?   @relation(fields: [agencyId], references: [id])
  assignedTo  User?     @relation("AssignedAgent", fields: [assignedToId], references: [id])
  campaign    Campaign? @relation(fields: [campaignId], references: [id])

  passengers    ReservationPassenger[]
  extras        ReservationExtra[]
  payments      Payment[]
  refunds       Refund[]
  commissions   Commission[]
  documents     Document[]
  messages      Message[]
  seatHolds     SeatHold[]
  notifications Notification[]
  opportunity   CrmOpportunity?
  activities    CrmActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([tourDateId])
  @@index([customerId])
  @@index([agencyId])
  @@index([assignedToId])
  @@map("reservations")
}

model ReservationPassenger {
  id              String       @id @default(cuid())
  reservationId   String
  paxType         PaxType
  isLead          Boolean      @default(false)
  firstName       String
  lastName        String
  birthDate       DateTime?
  nationality     String?
  phone           String?
  email           String?
  roomTypeId      String?
  roomGroup       Int?
  specialRequests String?
  emergencyName   String?
  emergencyPhone  String?
  reservation     Reservation  @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  roomType        RoomType?    @relation(fields: [roomTypeId], references: [id])
  documents       Document[]
  @@index([reservationId])
  @@map("reservation_passengers")
}

model ReservationExtra {
  id              String        @id @default(cuid())
  reservationId   String
  optionalExtraId String
  quantity        Int           @default(1)
  unitPriceMinor  Int
  currency        String        @default("EUR")
  reservation     Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  optionalExtra   OptionalExtra @relation(fields: [optionalExtraId], references: [id])
  @@map("reservation_extras")
}

// ──────────────────────────── money ────────────────────────────
model Payment {
  id            String        @id @default(cuid())
  reservationId String
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  amountMinor   Int
  currency      String        @default("TRY")
  provider      String?       // iyzico | stripe | manual
  providerRef   String?
  paidAt        DateTime?
  recordedById  String?
  note          String?
  reservation   Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  recordedBy    User?         @relation(fields: [recordedById], references: [id])
  refunds       Refund[]
  createdAt     DateTime      @default(now())
  @@index([reservationId])
  @@index([status])
  @@map("payments")
}

model Refund {
  id            String       @id @default(cuid())
  reservationId String
  paymentId     String?
  amountMinor   Int
  currency      String       @default("TRY")
  status        RefundStatus @default(REQUESTED)
  reason        String?
  requestedById String?
  approvedById  String?
  processedAt   DateTime?
  reservation   Reservation  @relation(fields: [reservationId], references: [id])
  payment       Payment?     @relation(fields: [paymentId], references: [id])
  requestedBy   User?        @relation("RefundRequestedBy", fields: [requestedById], references: [id])
  approvedBy    User?        @relation("RefundApprovedBy", fields: [approvedById], references: [id])
  createdAt     DateTime     @default(now())
  @@index([reservationId])
  @@map("refunds")
}

model Commission {
  id            String           @id @default(cuid())
  reservationId String
  agencyId      String?
  basisMinor    Int
  percent       Decimal          @db.Decimal(5, 2)
  amountMinor   Int
  currency      String           @default("TRY")
  status        CommissionStatus @default(ACCRUED)
  settledAt     DateTime?
  reservation   Reservation      @relation(fields: [reservationId], references: [id])
  agency        Agency?          @relation(fields: [agencyId], references: [id])
  createdAt     DateTime         @default(now())
  @@index([agencyId, status])
  @@map("commissions")
}

// ──────────────────────────── supply ───────────────────────────
model Supplier {
  id              String       @id @default(cuid())
  type            SupplierType
  name            String
  contactName     String?
  email           String?
  phone           String?
  country         String?
  defaultCurrency String?
  notes           String?
  isActive        Boolean      @default(true)
  hotels          Hotel[]
  transports      Transport[]
  tours           Tour[]
  createdAt       DateTime     @default(now())
  @@map("suppliers")
}

model Hotel {
  id          String               @id @default(cuid())
  supplierId  String?
  name        String
  city        String
  country     String
  category    HotelCategory        @default(FOUR_STAR)
  address     String?
  phone       String?
  notes       String?
  supplier    Supplier?            @relation(fields: [supplierId], references: [id])
  allocations TourDateAllocation[]
  @@map("hotels")
}

model Transport {
  id          String               @id @default(cuid())
  supplierId  String?
  type        TransportType
  name        String
  depAirport  String?
  arrAirport  String?
  notes       String?
  supplier    Supplier?            @relation(fields: [supplierId], references: [id])
  allocations TourDateAllocation[]
  @@map("transports")
}

model TourDateAllocation {
  id           String     @id @default(cuid())
  tourDateId   String
  hotelId      String?
  transportId  String?
  roomsBlocked Int?
  seatsBlocked Int?
  costMinor    Int?
  currency     String?
  confirmed    Boolean    @default(false)
  supplierRef  String?
  tourDate     TourDate   @relation(fields: [tourDateId], references: [id], onDelete: Cascade)
  hotel        Hotel?     @relation(fields: [hotelId], references: [id])
  transport    Transport? @relation(fields: [transportId], references: [id])
  @@map("tour_date_allocations")
}

// ──────────────────────────── b2b ──────────────────────────────
model Agency {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  contactName      String
  email            String
  phone            String
  taxNo            String?
  address          String?
  status           AgencyStatus  @default(PENDING)
  pricingTier      AgencyTier    @default(STANDARD)
  commissionPercent Decimal      @db.Decimal(5, 2) @default(0)
  creditLimitMinor Int           @default(0)
  balanceMinor     Int           @default(0)
  currency         String        @default("TRY")
  members          AgencyUser[]
  reservations     Reservation[]
  commissions      Commission[]
  messages         Message[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  @@map("agencies")
}

model AgencyUser {
  id       String  @id @default(cuid())
  agencyId String
  userId   String
  isOwner  Boolean @default(false)
  agency   Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([agencyId, userId])
  @@map("agency_users")
}

// ──────────────────────────── content ──────────────────────────
model BlogPost {
  id             String        @id @default(cuid())
  slug           String        @unique
  titleTr        String
  excerptTr      String?
  bodyTr         String
  coverImageKey  String?
  destinationId  String?
  tourId         String?
  authorId       String?
  status         ContentStatus @default(DRAFT)
  publishedAt    DateTime?
  seoTitle       String?
  seoDescription String?
  tags           Json?
  destination    Destination?  @relation(fields: [destinationId], references: [id])
  tour           Tour?         @relation(fields: [tourId], references: [id])
  author         User?         @relation(fields: [authorId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  @@index([status])
  @@map("blog_posts")
}

model Page {
  id             String       @id @default(cuid())
  slug           String       @unique
  titleTr        String
  bodyTr         String?      // legacy/simple rich-text fallback
  blocks         Json         @default("[]") // published block tree
  draftBlocks    Json?        // live-preview working copy; promoted to blocks on save
  template       PageTemplate @default(DEFAULT)
  status         PageStatus   @default(DRAFT)
  parentId       String?
  sortOrder      Int          @default(0)
  seoTitle       String?
  seoDescription String?
  ogImageKey     String?
  noindex        Boolean      @default(false)
  isSystem       Boolean      @default(false) // legal pages: editable, not deletable
  authorId       String?
  publishedAt    DateTime?
  scheduledAt    DateTime?
  parent         Page?          @relation("PageTree", fields: [parentId], references: [id])
  children       Page[]         @relation("PageTree")
  author         User?          @relation("PageAuthor", fields: [authorId], references: [id])
  revisions      PageRevision[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  @@index([status])
  @@index([parentId])
  @@map("pages")
}

model Testimonial {
  id           String  @id @default(cuid())
  customerName String
  avatarKey    String?
  tourId       String?
  rating       Int
  bodyTr       String
  isPublished  Boolean @default(true)
  sortOrder    Int     @default(0)
  tour         Tour?   @relation(fields: [tourId], references: [id])
  @@map("testimonials")
}

// ──────────────────────────── system ───────────────────────────
model Setting {
  id           String   @id @default(cuid())
  key          String   @unique
  valueJson    Json
  group        String
  updatedById  String?
  updatedBy    User?    @relation(fields: [updatedById], references: [id])
  updatedAt    DateTime @updatedAt
  @@map("settings")
}

model NotificationTemplate {
  id       String   @id @default(cuid())
  type     NotificationType
  channel  MessageChannel
  locale   String   @default("tr")
  subject  String?
  body     String
  isActive Boolean  @default(true)
  @@unique([type, channel, locale])
  @@map("notification_templates")
}

model Notification {
  id            String             @id @default(cuid())
  type          NotificationType
  channel       MessageChannel
  toEmail       String?
  toPhone       String?
  reservationId String?
  userId        String?
  payload       Json
  status        NotificationStatus @default(QUEUED)
  sentAt        DateTime?
  error         String?
  reservation   Reservation?       @relation(fields: [reservationId], references: [id])
  user          User?              @relation(fields: [userId], references: [id])
  createdAt     DateTime           @default(now())
  @@index([status])
  @@index([reservationId])
  @@map("notifications")
}

model AuditLog {
  id          String    @id @default(cuid())
  actorUserId String?
  actorRealm  UserRealm
  action      String
  entity      String
  entityId    String
  before      Json?
  after       Json?
  ip          String?
  userAgent   String?
  actor       User?     @relation(fields: [actorUserId], references: [id])
  createdAt   DateTime  @default(now())
  @@index([entity, entityId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ════════════════════════ CRM (doc 08) ════════════════════════
enum LifecycleStage {
  SUBSCRIBER
  LEAD
  OPPORTUNITY
  CUSTOMER
  REPEAT_CUSTOMER
  LOST
}
enum OpportunityStatus {
  OPEN
  WON
  LOST
}
enum ActivityType {
  CALL
  EMAIL
  WHATSAPP
  MEETING
  NOTE
  TASK
  SMS
}
enum ActivityStatus {
  PENDING
  DONE
  CANCELLED
}
enum SegmentType {
  DYNAMIC
  STATIC
}
enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}
enum RecipientStatus {
  QUEUED
  SENT
  OPENED
  CLICKED
  BOUNCED
  FAILED
}
enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTISELECT
}
enum CrmEntityType {
  CONTACT
  OPPORTUNITY
}
model CrmPipeline {
  id            String           @id @default(cuid())
  name          String
  isDefault     Boolean          @default(false)
  sortOrder     Int              @default(0)
  stages        CrmStage[]
  opportunities CrmOpportunity[]
  createdAt     DateTime         @default(now())
  @@map("crm_pipelines")
}

model CrmStage {
  id            String           @id @default(cuid())
  pipelineId    String
  name          String
  probability   Int              @default(0)
  sortOrder     Int              @default(0)
  isWon         Boolean          @default(false)
  isLost        Boolean          @default(false)
  pipeline      CrmPipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  opportunities CrmOpportunity[]
  @@map("crm_stages")
}

model CrmOpportunity {
  id                 String            @id @default(cuid())
  title              String
  customerId         String
  ownerId            String?
  pipelineId         String
  stageId            String
  destinationId      String?
  tourId             String?
  reservationId      String?           @unique
  status             OpportunityStatus @default(OPEN)
  estValueMinor      Int?
  currency           String            @default("EUR")
  expectedTravelDate DateTime?
  adults             Int?
  children           Int?
  source             String?
  lostReason         String?
  closedAt           DateTime?
  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  owner       User?        @relation(fields: [ownerId], references: [id])
  pipeline    CrmPipeline  @relation(fields: [pipelineId], references: [id])
  stage       CrmStage     @relation(fields: [stageId], references: [id])
  destination Destination? @relation(fields: [destinationId], references: [id])
  tour        Tour?        @relation(fields: [tourId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])
  activities  CrmActivity[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  @@index([customerId])
  @@index([stageId])
  @@index([ownerId])
  @@map("crm_opportunities")
}

model CrmActivity {
  id            String          @id @default(cuid())
  type          ActivityType
  status        ActivityStatus  @default(PENDING)
  subject       String
  body          String?
  dueAt         DateTime?
  completedAt   DateTime?
  customerId    String?
  opportunityId String?
  reservationId String?
  assignedToId  String?
  createdById   String?
  meta          Json?
  customer    Customer?       @relation(fields: [customerId], references: [id])
  opportunity CrmOpportunity? @relation(fields: [opportunityId], references: [id])
  reservation Reservation?    @relation(fields: [reservationId], references: [id])
  assignedTo  User?           @relation("ActivityAssignee", fields: [assignedToId], references: [id])
  createdBy   User?           @relation("ActivityCreator", fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())
  @@index([assignedToId, status])
  @@index([customerId])
  @@index([dueAt])
  @@map("crm_activities")
}

model CrmTag {
  id        String        @id @default(cuid())
  name      String        @unique
  color     String?
  customers CustomerTag[]
  @@map("crm_tags")
}

model CustomerTag {
  customerId String
  tagId      String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag        CrmTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([customerId, tagId])
  @@map("customer_tags")
}

model CrmSegment {
  id          String             @id @default(cuid())
  name        String
  type        SegmentType        @default(DYNAMIC)
  filterJson  Json?
  createdById String?
  createdBy   User?              @relation(fields: [createdById], references: [id])
  members     CrmSegmentMember[]
  campaigns   EmailCampaign[]
  createdAt   DateTime           @default(now())
  @@map("crm_segments")
}

model CrmSegmentMember {
  segmentId  String
  customerId String
  segment    CrmSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  @@id([segmentId, customerId])
  @@map("crm_segment_members")
}

model EmailCampaign {
  id          String                   @id @default(cuid())
  name        String
  subject     String
  body        String
  segmentId   String?
  status      EmailCampaignStatus      @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdById String?
  stats       Json?
  segment     CrmSegment?              @relation(fields: [segmentId], references: [id])
  createdBy   User?                    @relation(fields: [createdById], references: [id])
  recipients  EmailCampaignRecipient[]
  createdAt   DateTime                 @default(now())
  @@map("email_campaigns")
}

model EmailCampaignRecipient {
  id         String          @id @default(cuid())
  campaignId String
  customerId String
  status     RecipientStatus @default(QUEUED)
  sentAt     DateTime?
  campaign   EmailCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer   Customer        @relation(fields: [customerId], references: [id])
  @@unique([campaignId, customerId])
  @@map("email_campaign_recipients")
}

model CustomField {
  id        String             @id @default(cuid())
  entity    CrmEntityType
  key       String
  label     String
  type      CustomFieldType
  options   Json?
  required  Boolean            @default(false)
  sortOrder Int                @default(0)
  values    CustomFieldValue[]
  @@unique([entity, key])
  @@map("custom_fields")
}

model CustomFieldValue {
  id        String        @id @default(cuid())
  fieldId   String
  entity    CrmEntityType
  entityId  String
  valueJson Json
  field     CustomField   @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  @@unique([fieldId, entityId])
  @@index([entity, entityId])
  @@map("custom_field_values")
}

// ════════════════════════ CMS / page builder (doc 09) ════════════════════════
enum PageStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}
enum PageTemplate {
  DEFAULT
  FULL_WIDTH
  LANDING
  WITH_SIDEBAR
}
enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
}
enum MenuLocation {
  HEADER
  FOOTER
  MOBILE
  SIDEBAR
}
enum MenuItemType {
  PAGE
  DESTINATION
  TOUR
  BLOG
  CUSTOM_URL
}
enum BlockScope {
  GLOBAL
  REUSABLE
}
enum FormSubmissionStatus {
  NEW
  READ
  ARCHIVED
  SPAM
}
enum RedirectType {
  PERMANENT
  TEMPORARY
  GONE
}
model PageRevision {
  id        String   @id @default(cuid())
  pageId    String
  editorId  String?
  title     String
  blocks    Json
  note      String?
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  editor    User?    @relation("PageRevisionEditor", fields: [editorId], references: [id])
  createdAt DateTime @default(now())
  @@index([pageId])
  @@map("page_revisions")
}

model ContentBlock {
  id        String     @id @default(cuid())
  key       String     @unique
  name      String
  scope     BlockScope @default(REUSABLE)
  blocks    Json
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  @@map("content_blocks")
}

model Menu {
  id        String       @id @default(cuid())
  name      String
  location  MenuLocation @unique
  items     MenuItem[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  @@map("menus")
}

model MenuItem {
  id        String       @id @default(cuid())
  menuId    String
  parentId  String?
  label     String
  type      MenuItemType @default(CUSTOM_URL)
  entityId  String? // page/destination/tour/blog id, resolved at render
  url       String?
  newTab    Boolean      @default(false)
  sortOrder Int          @default(0)
  isActive  Boolean      @default(true)
  menu      Menu         @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent    MenuItem?    @relation("MenuItemTree", fields: [parentId], references: [id])
  children  MenuItem[]   @relation("MenuItemTree")
  @@index([menuId])
  @@map("menu_items")
}

model Media {
  id           String    @id @default(cuid())
  fileKey      String    @unique
  fileName     String
  type         MediaType @default(IMAGE)
  mimeType     String
  sizeBytes    Int
  width        Int?
  height       Int?
  alt          String?
  caption      String?
  folder       String?
  uploadedById String?
  uploadedBy   User?     @relation("MediaUploader", fields: [uploadedById], references: [id])
  createdAt    DateTime  @default(now())
  @@index([folder])
  @@map("media")
}

model Redirect {
  id        String       @id @default(cuid())
  fromPath  String       @unique
  toPath    String
  type      RedirectType @default(PERMANENT)
  isActive  Boolean      @default(true)
  hits      Int          @default(0)
  createdAt DateTime     @default(now())
  @@map("redirects")
}

model Form {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  fields      Json             @default("[]")
  settings    Json? // notifyEmail, successMessage, createLead, consent
  isActive    Boolean          @default(true)
  submissions FormSubmission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  @@map("forms")
}

model FormSubmission {
  id        String               @id @default(cuid())
  formId    String
  data      Json
  status    FormSubmissionStatus @default(NEW)
  leadId    String?
  ip        String?
  userAgent String?
  form      Form                 @relation(fields: [formId], references: [id], onDelete: Cascade)
  lead      Lead?                @relation(fields: [leadId], references: [id])
  createdAt DateTime             @default(now())
  @@index([formId, status])
  @@map("form_submissions")
}
